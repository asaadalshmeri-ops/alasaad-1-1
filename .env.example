# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key for signing JSON Web Tokens.
JWT_SECRET="super-secret-lms-jwt-token-key-2026"

# SUPABASE_URL: Your Supabase Project URL (found in Project Settings > API).
SUPABASE_URL="MY_SUPABASE_URL"

# SUPABASE_KEY: Your Supabase Anon Public Key or Service Role Key.
SUPABASE_KEY="MY_SUPABASE_KEY"

# GITHUB_CLIENT_ID: Your GitHub OAuth Application Client ID for GitHub Login integration.
GITHUB_CLIENT_ID="MY_GITHUB_CLIENT_ID"

# GITHUB_CLIENT_SECRET: Your GitHub OAuth Application Client Secret for GitHub Login integration.
GITHUB_CLIENT_SECRET="MY_GITHUB_CLIENT_SECRET"
